{
  "id": "todo-list-plugin",
  "name": "todo-list-plugin",
  "description": "Add, list, update, and remove todos in OpenClaw",
  "contracts": {
    "tools": [
      "todo_list_add",
      "todo_list_get",
      "todo_list_update",
      "todo_list_remove"
    ]
  },
  "orbit": {
    "billing": true
  },
  "activation": {
    "onStartup": true
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "privateKey": {
        "type": "string",
        "description": "Wallet private key for Orbit billing (0x + 64 hex chars)"
      }
    }
  }
}
